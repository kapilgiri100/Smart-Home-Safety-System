# PostgreSQL connection - either a single URL...
DATABASE_URL="postgresql://postgres:12345@localhost:5432/smart_home_db"

# ...or discrete vars (used only if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=12345
PGDATABASE=smart_home_db

# Server
PORT=5000
# Comma-separated list of allowed frontend origins (local dev + Render frontend URL)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-url.onrender.com

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Shared secret the ESP32 sends on every request so the backend can trust it
DEVICE_API_KEY=replace_with_a_long_random_device_key
